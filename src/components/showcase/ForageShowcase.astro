---
import ScreenFrame from '../ScreenFrame.astro';
import ForageScreen from '../screens/ForageScreen.astro';
---
<div class="grid">
  <div class="span-2">
    <ScreenFrame caption="The storefront — weight, unit price and container, before anything else.">
      <ForageScreen />
    </ScreenFrame>
  </div>

  <ScreenFrame kind="plain" caption="Label system — every jar tells you how it comes back.">
    <div class="label-panel" aria-hidden="true">
      <div class="label">
        <p class="lb-brand">FORAGE</p>
        <p class="lb-name">Rolled Oats</p>
        <p class="lb-meta">500g — refill nº 12</p>
        <hr />
        <p class="lb-return">return the jar · 50p back</p>
      </div>
    </div>
  </ScreenFrame>

  <div class="stack">
    <ScreenFrame kind="phone" caption="Product page — refills as a two-tap routine.">
      <div class="pdp" aria-hidden="true">
        <div class="pd-img"></div>
        <p class="pd-name">Rolled oats</p>
        <p class="pd-meta">£0.32 / 100g · 500g</p>
        <p class="pd-container">Arrives in: returned jar</p>
        <span class="pd-btn">Add to this week’s basket</span>
        <p class="pd-tally">412 g packaging avoided this order</p>
      </div>
    </ScreenFrame>
  </div>

  <div class="span-2">
    <ScreenFrame kind="plain" caption="The catalogue, rebuilt around routines — not categories.">
      <div class="routines" aria-hidden="true">
        <p class="r-head">Shop by routine</p>
        <div class="chips">
          <span class="chip active">Weekly basics</span>
          <span class="chip">Pantry refill</span>
          <span class="chip">Fresh swap</span>
          <span class="chip">First-time kit</span>
        </div>
        <p class="r-sub">Your weekly basics, remembered — reorder in two taps.</p>
      </div>
    </ScreenFrame>
  </div>
</div>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); align-items: start; }
  .span-2 { grid-column: 1 / -1; }
  .stack { justify-self: center; }

  .label-panel { background: #EFE8DA; padding: clamp(1.8rem, 5vw, 3rem); display: grid; place-items: center; }
  .label { background: #FDFBF6; border: 2px solid #20231D; border-radius: 6px; padding: 1.6rem 2rem; text-align: center; max-width: 280px; }
  .lb-brand { font-size: 0.78rem; letter-spacing: 0.34em; font-weight: 700; color: #3D4A32; }
  .lb-name { font-family: var(--font-display); font-size: 1.7rem; margin-block: 0.5rem 0.2rem; color: #20231D; }
  .lb-meta { font-size: 0.82rem; color: #3D4A32; }
  .label hr { border: 0; border-top: 1px solid #B66E41; width: 44px; margin: 0.9rem auto; }
  .lb-return { font-size: 0.78rem; font-style: italic; color: #20231D; }

  .pdp { background: #EFE8DA; color: #20231D; padding: 1.4rem; }
  .pd-img { background: #B66E41; border-radius: 10px; aspect-ratio: 4 / 3; margin-bottom: 0.8rem; }
  .pd-name { font-family: var(--font-display); font-size: 1.3rem; font-weight: 600; }
  .pd-meta { font-size: 0.9rem; color: #3D4A32; margin-block: 0.15rem; }
  .pd-container { font-size: 0.8rem; font-style: italic; color: #20231D; margin-bottom: 1rem; }
  .pd-btn { display: block; text-align: center; background: #3D4A32; color: #EFE8DA; border-radius: 999px; padding: 0.7rem 1rem; font-size: 0.9rem; font-weight: 600; }
  .pd-tally { margin-top: 0.9rem; padding-top: 0.7rem; border-top: 1px solid rgba(32, 35, 29, 0.2); font-size: 0.8rem; font-weight: 600; color: #3D4A32; }

  .routines { background: #3D4A32; color: #EFE8DA; padding: clamp(1.8rem, 5vw, 3rem); }
  .r-head { font-family: var(--font-display); font-size: var(--step-2); margin-bottom: 1.1rem; }
  .chips { display: flex; flex-wrap: wrap; gap: 0.6rem; margin-bottom: 1.1rem; }
  .chip { border: 1px solid rgba(239, 232, 218, 0.5); border-radius: 999px; padding: 0.45rem 1.1rem; font-size: 0.9rem; }
  .chip.active { background: #EFE8DA; color: #20231D; border-color: #EFE8DA; font-weight: 600; }
  .r-sub { font-size: 0.92rem; color: rgba(239, 232, 218, 0.85); }

  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
