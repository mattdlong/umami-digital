---
import ScreenFrame from '../ScreenFrame.astro';
import EmberScreen from '../screens/EmberScreen.astro';
---
<div class="grid">
  <div class="span-2">
    <ScreenFrame caption="The booking flow — three steps, fully in the group’s voice.">
      <EmberScreen />
    </ScreenFrame>
  </div>

  <ScreenFrame kind="plain" caption="Menu suite — one typographic skeleton, dialled per venue.">
    <div class="menu" aria-hidden="true">
      <p class="m-venue">The Grill Room</p>
      <p class="m-sub">Dinner — Summer</p>
      <hr />
      <div class="dish"><span>Charred hispi, smoked butter</span><span class="price">9</span></div>
      <div class="dish"><span>Dry-aged ribeye, bone marrow</span><span class="price">34</span></div>
      <div class="dish"><span>Whole plaice, brown shrimp</span><span class="price">28</span></div>
      <div class="dish"><span>Burnt cream, fig leaf</span><span class="price">8</span></div>
      <p class="m-foot">ember group — venue nº 1</p>
    </div>
  </ScreenFrame>

  <div class="stack">
    <ScreenFrame kind="phone" caption="Confirmation — the most branded moment of the journey.">
      <div class="confirm" aria-hidden="true">
        <p class="c-check">✓</p>
        <p class="c-title">Table confirmed</p>
        <p class="c-meta">The Grill Room<br />Fri 26 Jun · 19:30 · 4 guests</p>
        <span class="c-btn">Add to calendar</span>
      </div>
    </ScreenFrame>
  </div>

  <div class="span-2">
    <ScreenFrame kind="plain" caption="Five rooms, one hand — venue lockups dial the heat up or down.">
      <div class="lockups" aria-hidden="true">
        <p class="l1">THE GRILL ROOM</p>
        <p class="l2">Cinder</p>
        <p class="l3">Ash &amp; Oak</p>
      </div>
    </ScreenFrame>
  </div>
</div>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); align-items: start; }
  .span-2 { grid-column: 1 / -1; }
  .stack { justify-self: center; }

  .menu { background: #1C1A17; color: #F4EFE6; padding: clamp(1.5rem, 4vw, 2.5rem); }
  .m-venue { font-family: var(--font-display); font-size: var(--step-2); font-weight: 600; letter-spacing: -0.02em; }
  .m-sub { font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.16em; color: #A39E94; margin-block: 0.4rem 1rem; }
  hr { border: 0; border-top: 1px solid #D8491B; width: 56px; margin: 0 0 1.2rem; }
  .dish { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; font-family: var(--font-display); font-size: 1.05rem; padding-block: 0.45rem; border-bottom: 1px dotted rgba(163, 158, 148, 0.35); }
  .price { font-family: var(--font-text); font-size: 0.9rem; color: #F4EFE6; }
  .m-foot { margin-top: 1.2rem; font-size: 0.72rem; letter-spacing: 0.16em; text-transform: uppercase; color: #A39E94; }

  .confirm { background: #1C1A17; color: #F4EFE6; padding: 2.2rem 1.6rem; text-align: center; }
  .c-check { width: 52px; height: 52px; border-radius: 50%; background: #D8491B; color: #F4EFE6; font-size: 1.5rem; line-height: 52px; margin-inline: auto; }
  .c-title { font-family: var(--font-display); font-size: 1.5rem; margin-block: 1rem 0.5rem; }
  .c-meta { font-size: 0.9rem; color: #A39E94; line-height: 1.6; margin-bottom: 1.4rem; }
  .c-btn { display: inline-block; border: 1px solid #A39E94; border-radius: 999px; padding: 0.55rem 1.3rem; font-size: 0.85rem; font-weight: 600; }

  .lockups { background: #F4EFE6; color: #1C1A17; padding: clamp(1.8rem, 5vw, 3rem); display: grid; gap: 1rem; }
  .lockups p { font-family: var(--font-display); line-height: 1; }
  .l1 { font-weight: 700; font-size: clamp(1.6rem, 4vw, 2.6rem); letter-spacing: 0.04em; }
  .l2 { font-weight: 500; font-style: italic; font-size: clamp(1.8rem, 4.5vw, 3rem); color: #D8491B; }
  .l3 { font-weight: 380; font-size: clamp(1.7rem, 4.2vw, 2.8rem); letter-spacing: 0.12em; }

  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
