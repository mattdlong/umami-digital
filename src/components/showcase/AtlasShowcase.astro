---
import ScreenFrame from '../ScreenFrame.astro';
import AtlasScreen from '../screens/AtlasScreen.astro';
---
<div class="grid">
  <div class="span-2">
    <ScreenFrame caption="The dashboard — one number, machinery revealed progressively.">
      <AtlasScreen />
    </ScreenFrame>
  </div>

  <div class="stack">
    <ScreenFrame kind="phone" caption="The tax pot — set aside automatically, explained in place.">
      <div class="taxpot" aria-hidden="true">
        <p class="t-k">Tax pot</p>
        <p class="t-big">£4,260</p>
        <p class="t-rule">23% of every invoice, set aside the moment it’s paid</p>
        <div class="t-row"><span>Invoice #041</span><span class="t-num">+ £276</span></div>
        <div class="t-row"><span>Invoice #040</span><span class="t-num">+ £368</span></div>
        <div class="t-row"><span>Invoice #039</span><span class="t-num">+ £184</span></div>
      </div>
    </ScreenFrame>
  </div>

  <ScreenFrame kind="plain" caption="Shipped as a system — tokens and components, not just screens.">
    <div class="sheet" aria-hidden="true">
      <div class="sw-row">
        <span class="sw" style="background:#10182B"></span>
        <span class="sw" style="background:#2E5BFF"></span>
        <span class="sw" style="background:#5A6478"></span>
        <span class="sw sw-light" style="background:#F2F4F8"></span>
      </div>
      <span class="b-primary">Send invoice</span>
      <span class="b-secondary">Preview</span>
      <div class="input"><span class="in-label">Day rate</span><span class="in-val">£420</span></div>
    </div>
  </ScreenFrame>

  <div class="span-2">
    <ScreenFrame kind="plain" caption="Invoices feed the engine — smoothing scheduled before the money lands.">
      <div class="invoice" aria-hidden="true">
        <div class="inv-left">
          <p class="inv-id">Invoice #042</p>
          <p class="inv-meta">Due in 6 days</p>
        </div>
        <p class="inv-amount">£1,200</p>
        <span class="inv-pill">Smoothing scheduled</span>
      </div>
    </ScreenFrame>
  </div>
</div>

<style>
  .grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); align-items: start; }
  .span-2 { grid-column: 1 / -1; }
  .stack { justify-self: center; }

  .taxpot { background: #10182B; color: #F2F4F8; padding: 1.6rem 1.4rem; }
  .t-k { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.12em; color: #8C96AC; }
  .t-big { font-size: 2.3rem; font-weight: 700; font-variant-numeric: tabular-nums; margin-block: 0.2rem 0.5rem; }
  .t-rule { font-size: 0.82rem; color: #8C96AC; margin-bottom: 1.1rem; }
  .t-row { display: flex; justify-content: space-between; font-size: 0.88rem; border-top: 1px solid rgba(90, 100, 120, 0.35); padding-block: 0.55rem; }
  .t-num { font-variant-numeric: tabular-nums; color: #F2F4F8; font-weight: 600; }

  .sheet { background: #F2F4F8; padding: clamp(1.6rem, 4vw, 2.4rem); display: grid; gap: 1rem; justify-items: start; }
  .sw-row { display: flex; gap: 0.6rem; }
  .sw { width: 38px; height: 38px; border-radius: 10px; display: inline-block; }
  .sw-light { border: 1px solid rgba(16, 24, 43, 0.2); }
  .b-primary { background: #2E5BFF; color: #F2F4F8; border-radius: 10px; padding: 0.65rem 1.4rem; font-weight: 600; font-size: 0.92rem; }
  .b-secondary { border: 1.5px solid #10182B; color: #10182B; border-radius: 10px; padding: 0.65rem 1.4rem; font-weight: 600; font-size: 0.92rem; }
  .input { border: 1.5px solid rgba(16, 24, 43, 0.25); border-radius: 10px; padding: 0.55rem 0.9rem; display: grid; gap: 0.1rem; min-width: 180px; background: #fff; }
  .in-label { font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.1em; color: #3d465c; }
  .in-val { font-weight: 600; color: #10182B; }

  .invoice { background: #10182B; color: #F2F4F8; padding: clamp(1.4rem, 4vw, 2.2rem); display: flex; align-items: center; gap: 1.5rem; flex-wrap: wrap; }
  .inv-id { font-weight: 650; font-size: 1.05rem; }
  .inv-meta { font-size: 0.85rem; color: #8C96AC; }
  .inv-amount { font-size: 1.8rem; font-weight: 700; font-variant-numeric: tabular-nums; margin-left: auto; }
  .inv-pill { border: 1px solid #2E5BFF; color: #9DB4FF; border-radius: 999px; padding: 0.4rem 1rem; font-size: 0.82rem; font-weight: 600; }

  @media (max-width: 760px) { .grid { grid-template-columns: 1fr; } }
</style>
