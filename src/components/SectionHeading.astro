---
interface Props { eyebrow: string; title: string }
const { eyebrow, title } = Astro.props;
// title may contain <em> for the italic accent word; a trailing period becomes the red dot
const html = title.endsWith('.') ? `${title.slice(0, -1)}<span class="dot">.</span>` : title;
---
<div class="section-heading reveal">
  <p class="eyebrow">{eyebrow}</p>
  <h2 class="rise"><span class="rise-inner" set:html={html} /></h2>
</div>

<style>
  .section-heading { margin-bottom: var(--space-4); }
  .eyebrow { margin-bottom: 0.6rem; }
  h2 { font-size: var(--step-3); }
</style>
