---
interface Props { caption: string; kind?: 'browser' | 'phone' | 'plain' }
const { caption, kind = 'browser' } = Astro.props;
---
<figure class={`frame reveal ${kind}`}>
  {kind === 'browser' && <div class="chrome" aria-hidden="true"><i></i><i></i><i></i></div>}
  {kind === 'phone' && <div class="notch" aria-hidden="true"></div>}
  <div class="screen"><slot /></div>
  <figcaption class="muted">{caption}</figcaption>
</figure>

<style>
  .frame { margin: 0; }
  .chrome {
    display: flex; gap: 6px; padding: 10px 14px;
    background: var(--ink); border-radius: 14px 14px 0 0;
  }
  .chrome i { width: 9px; height: 9px; border-radius: 50%; background: rgba(250, 247, 242, 0.3); }
  .browser .screen { border: 1px solid var(--hairline); border-top: 0; border-radius: 0 0 14px 14px; overflow: hidden; }
  .phone { max-width: 310px; }
  .phone .notch { height: 24px; background: var(--ink); border-radius: 24px 24px 0 0; position: relative; }
  .phone .notch::after {
    content: ''; position: absolute; left: 50%; top: 10px; transform: translateX(-50%);
    width: 64px; height: 5px; border-radius: 3px; background: rgba(250, 247, 242, 0.35);
  }
  .phone .screen { border: 1px solid var(--hairline); border-top: 0; border-radius: 0 0 24px 24px; overflow: hidden; }
  .plain .screen { border: 1px solid var(--hairline); border-radius: 14px; overflow: hidden; }
  figcaption { font-size: 0.85rem; margin-top: 0.75rem; }
</style>
