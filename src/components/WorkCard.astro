---
import ProjectArt from './ProjectArt.astro';

interface Props {
  slug: string;
  codename: string;
  sector: string;
  engagement: string;
  services: string[];
  index: number;
  tint: string;
}
const { slug, codename, sector, engagement, services, index, tint } = Astro.props;
const num = String(index).padStart(2, '0');
---
<a href={`/work/${slug}/`} class="work-card reveal" style={`--tint:${tint}`}>
  <div class="art-panel" transition:name={`art-${slug}`}>
    <ProjectArt slug={slug as 'ember' | 'forage' | 'atlas'} />
  </div>
  <div class="info">
    <span class="num" aria-hidden="true">{num}</span>
    <div class="head">
      <h3 class="codename" transition:name={`title-${slug}`}>{codename}</h3>
      <span class="arrow" aria-hidden="true">→</span>
    </div>
    <p class="line">{sector} — {engagement.toLowerCase()}</p>
    <ul class="tags" role="list">
      {services.map((s) => <li class="card-tag">{s}</li>)}
    </ul>
  </div>
</a>

<style>
  .work-card {
    --fg: var(--ink);
    --fg-soft: var(--ink-70);
    --tag-b: var(--hairline);
    display: grid;
    grid-template-columns: 7fr 5fr;
    gap: var(--space-4);
    align-items: center;
    text-decoration: none;
    border-top: 1px solid var(--hairline);
    padding: var(--space-4) var(--space-3);
    margin-inline: calc(-1 * var(--space-3));
    border-radius: 18px;
    transition: background 0.35s ease;
  }
  .work-card:hover {
    background: var(--tint);
    --fg: var(--ink);
    --fg-soft: var(--ink-70);
    --tag-b: rgba(20, 20, 20, 0.3);
  }
  .work-card:nth-child(even) { grid-template-columns: 5fr 7fr; }
  .work-card:nth-child(even) .art-panel { order: 2; }
  .art-panel { border-radius: 14px; overflow: hidden; aspect-ratio: 4 / 3; }
  .art-panel :global(svg) { transition: transform 0.6s cubic-bezier(0.2, 0.6, 0.2, 1); }
  .work-card:hover .art-panel :global(svg) { transform: scale(1.05); }
  .num { font-family: var(--font-display); font-size: var(--step-3); line-height: 1; color: var(--red); display: block; margin-bottom: var(--space-2); }
  .head { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; }
  .codename { font-size: var(--step-3); color: var(--fg); transition: color 0.35s ease; }
  .arrow { font-size: var(--step-2); color: var(--red-text); opacity: 0; transform: translateX(-8px); transition: opacity 0.25s ease, transform 0.25s ease; }
  .work-card:hover .arrow { opacity: 1; transform: none; }
  .line { color: var(--fg-soft); margin-block: 0.6rem 1rem; font-size: var(--step-1); font-family: var(--font-display); transition: color 0.35s ease; }
  .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; list-style: none; margin: 0; padding: 0; }
  .card-tag {
    font-size: 0.78rem; font-weight: 550; letter-spacing: 0.06em; text-transform: uppercase;
    padding: 0.3rem 0.85rem; border: 1px solid var(--tag-b); border-radius: 999px;
    color: var(--fg-soft); transition: color 0.35s ease, border-color 0.35s ease;
  }
  @media (max-width: 760px) {
    .work-card { grid-template-columns: 1fr; gap: var(--space-3); margin-inline: -1.25rem; padding-inline: 1.25rem; }
    .work-card:nth-child(even) { grid-template-columns: 1fr; }
    .work-card:nth-child(even) .art-panel { order: 0; }
  }
</style>
